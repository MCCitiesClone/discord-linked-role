{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/api/index.ts"
    },
    {
      "src": "/linked-role",
      "dest": "/api/index.ts"
    },
    {
      "src": "/discord-oauth-callback",
      "dest": "/api/index.ts"
    },
    {
      "src": "/update-metadata",
      "dest": "/api/index.ts"
    },
    {
      "src": "/admin/metadata-schema",
      "dest": "/api/index.ts"
    }
  ]
}
