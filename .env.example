# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real secrets.

# --- Discord application ---
# From the Discord Developer Portal (https://discord.com/developers/applications)
# Bot token (Bot tab)
DISCORD_TOKEN=your-bot-token
# Application / OAuth2 client credentials (OAuth2 tab)
DISCORD_CLIENT_ID=your-application-id
DISCORD_CLIENT_SECRET=your-oauth2-client-secret
# Must exactly match a redirect added under OAuth2 → Redirects
DISCORD_REDIRECT_URI=http://localhost:3000/discord-oauth-callback

# Secret used to sign cookies (any long random string)
COOKIE_SECRET=replace-with-a-long-random-string

# --- Server ---
# Port the server listens on (defaults to 3000)
PORT=3000
# Set to "production" to mark cookies as secure
NODE_ENV=development

# --- Storage (optional) ---
# Upstash Redis / Vercel KV. If unset, an in-memory store is used (dev only).
# Provide either the UPSTASH_* or KV_* pair.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
